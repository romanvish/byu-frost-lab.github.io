---
import SectionedCardPage from '~/components/SectionedCardPage.astro';
import EntityCard from '~/components/EntityCard.astro';
import { CARD_IMAGE_SIZES, DEFAULT_CARD_IMAGE_STYLE } from '~/utils/card-images';
import { makePhotoResolver } from '~/utils/local-images';

const photoImports = ((import.meta as any).glob(
  '../../assets/images/robots/*.{jpg,jpeg,png,webp,avif}',
  { eager: true },
) as Record<string, any>);

const modules = ((import.meta as any).glob('../../content/robots/*.md', { eager: true }) as any);
const resolvePhoto = makePhotoResolver(photoImports);

const robots = Object.entries(modules).map(([path, mod]: [string, any]) => {
  const parts = path.split('/');
  const filename = parts[parts.length - 1];
  const slug = filename.replace(/\.md$/, '');
  return { slug, ...(mod.frontmatter || {}), photo: resolvePhoto(mod.frontmatter?.photo) };
});
robots.sort((a, b) => a.name.localeCompare(b.name));

const metadata = { title: 'Robots' };

const IMAGE_STYLE = DEFAULT_CARD_IMAGE_STYLE;
const IMAGE_DIMENSIONS = CARD_IMAGE_SIZES[IMAGE_STYLE];

function getGridClass() {
  return 'grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6';
}

const GROUPS = {
  robot: {
    title: 'Active Fleet',
    intro: 'We have a number of robots that we use to test our algorithms, system development, and implementations.',
  },
  retired: {
    title: 'Past Robots',
    intro: 'Retired robots that paved the way for our current research.',
  },
};

function membersByGroup(group) {
  return robots.filter((p) => (p.group || 'robot') === group);
}

function shuffle(arr) {
  const a = arr.slice();
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function getOrderedMembers(group) {
  const list = membersByGroup(group);
  return shuffle(list);
}
---

<SectionedCardPage
  metadata={metadata}
  title="Robots"
  intro="Exploring the boundaries of autonomous systems with our custom fleet."
>
  {Object.keys(GROUPS).map((g) => {
    const list = getOrderedMembers(g);
    return list.length ? (
      <>
        {g === 'retired' && <div class="my-16 border-t-2 border-gray-200 dark:border-gray-700 pt-12"></div>}
        <section class="mb-12">
          <div class="flex items-baseline justify-between mb-4">
            <h2 class="text-2xl font-semibold">{GROUPS[g].title}</h2>
          </div>
          <p class="text-muted mb-6 max-w-3xl">{GROUPS[g].intro}</p>

          <div class={getGridClass()}>
            {list.map((p, i) => (
              <EntityCard
                href={`/robots/${p.slug}`}
                title={p.name}
                subtitle={p.title}
                image={p.photo}
                imageAlt={p.name}
                imageStyle={IMAGE_STYLE}
                imageDimensions={IMAGE_DIMENSIONS}
                priority={g === 'robot' && i < 2}
                links={p.links}
                cardClass="intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade intersect-quarter"
              />
            ))}
          </div>
        </section>
      </>
    ) : null;
  })}
</SectionedCardPage>
