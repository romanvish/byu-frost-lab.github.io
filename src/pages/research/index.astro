---
import SectionedCardPage from '~/components/SectionedCardPage.astro';
import EntityCard from '~/components/EntityCard.astro';
import { DEFAULT_CARD_IMAGE_STYLE } from '~/utils/card-images';
import { makePhotoResolver } from '~/utils/local-images';

const photoImports = ((import.meta as any).glob(
  '../../assets/images/research_projects/*.{jpg,jpeg,png,webp,avif}',
  { eager: true },
) as Record<string, any>);

const modules = import.meta.glob("../../content/research_projects/*.md", {
  eager: true,
}) as any;
const resolvePhoto = makePhotoResolver(photoImports);

const research = Object.entries(modules).map(([path, mod]: [string, any]) => {
  const parts = path.split("/");
  const filename = parts[parts.length - 1];
  const slug = filename.replace(/\.md$/, "");
  return { slug, ...(mod.frontmatter || {}), photo: resolvePhoto(mod.frontmatter?.photo) };
});
research.sort((a, b) => {
  // Sort by start_date descending (newest first)
  const dateA = new Date(a.start_date || '1900-01-01');
  const dateB = new Date(b.start_date || '1900-01-01');
  if (dateB.getTime() !== dateA.getTime()) {
    return dateB.getTime() - dateA.getTime();
  }
  // Then sort alphabetically by project_name
  return a.project_name.localeCompare(b.project_name);
});

const metadata = { title: "Research" };

// Set the image style for index cards: 'rect' | 'square' | 'round'
// Change this value to quickly preview different styles.
const IMAGE_STYLE = DEFAULT_CARD_IMAGE_STYLE;

// Return grid classes for a group. Students use 5 columns on large screens.
function getGridClass(group) {
  if (group === "current_research")
    return "grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6";
  return "grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6";
}

const GROUPS = {
  current_research: {
    title: "Current Research Projects",
    // intro:
    //   "Our current research initiatives focus on developing robust field-robotic systems.",
  },
  previous_research: {
    title: "Previous Research Projects",
    // intro:
    //   "Our previous research projects from over the years.",
  }
};

function projectsByGroup(group) {
  return research.filter((p) => (p.group || "current_research") === group);
}
---

<SectionedCardPage metadata={metadata} maxWidthClass="max-w-6xl">
  <header slot="header" class="max-w-6xl mx-auto px-4 pt-12 pb-6">
    <h1 class="text-4xl md:text-5xl font-heading font-bold mb-3">Research</h1>
    <p class="text-lg text-muted max-w-3xl">
      The Field Robotic Systems Lab (FROST Lab) at Brigham Young University is focused on enabling the development of
      <em><strong>robust and reliable</strong></em> field-robotic systems that are able to
      <em><strong>consistently</strong> perceive, navigate,</em> and <em>perform work</em> in complex unstructured
      <em><strong>real-world</strong></em> environments.
    </p>
  </header>

  {Object.keys(GROUPS).map((g) => {
    const list = projectsByGroup(g);
    return list.length ? (
      <section class="mb-12">
        {g === 'previous_research' ? (
          <div class="my-16 border-t-2 border-gray-200 dark:border-gray-700 pt-12">
            <h2 class="text-3xl font-bold mb-2 text-center">Previous Projects</h2>
            <p class="text-center text-muted mb-12">
              Past research projects that shaped our lab’s direction and laid the groundwork for current efforts.
            </p>
          </div>
        ) : null}
        {g !== 'previous_research' && GROUPS[g].title ? (
          <div class="flex items-baseline justify-between mb-4">
            <h2 class="text-2xl font-semibold">{GROUPS[g].title}</h2>
          </div>
        ) : null}
        {g !== 'previous_research' && GROUPS[g].intro ? (
          <p class="text-muted mb-6 max-w-3xl">{GROUPS[g].intro}</p>
        ) : null}

        <div class={getGridClass(g)}>
          {list.map((p) => (
            <EntityCard
              href={`/research/${p.slug}`}
              title={p.project_name}
              subtitle={p.subtext}
              image={p.photo}
              imageAlt={p.project_name}
              imageStyle={IMAGE_STYLE}
              links={p.links}
              cardClass="intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade intersect-quarter"
            />
          ))}
        </div>
      </section>
    ) : null;
  })}
</SectionedCardPage>
