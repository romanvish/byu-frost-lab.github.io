---
import SectionedCardPage from '~/components/SectionedCardPage.astro';
import EntityCard from '~/components/EntityCard.astro';
import { CARD_IMAGE_SIZES, DEFAULT_CARD_IMAGE_STYLE } from '~/utils/card-images';
import { makePhotoResolver } from '~/utils/local-images';

const photoImports = ((import.meta as any).glob(
  '../../assets/images/people/**/*.{jpg,jpeg,png,webp,avif}',
  { eager: true },
) as Record<string, any>);

const modules = ((import.meta as any).glob('../../content/people/*.md', { eager: true }) as any);
const resolvePhoto = makePhotoResolver(photoImports);

const people = Object.entries(modules).map(([path, mod]: [string, any]) => {
  const parts = path.split('/');
  const filename = parts[parts.length - 1];
  const slug = filename.replace(/\.md$/, '');
  return { slug, ...(mod.frontmatter || {}), photo: resolvePhoto(mod.frontmatter?.photo) };
});
people.sort((a, b) => a.name.localeCompare(b.name));

const metadata = { title: 'Lab Members' };

// Set the image style for index cards: 'rect' | 'square' | 'round'
// Change this value to quickly preview different styles.
const IMAGE_STYLE = DEFAULT_CARD_IMAGE_STYLE;
const IMAGE_DIMENSIONS = CARD_IMAGE_SIZES[IMAGE_STYLE];

// Return grid classes for a group. Students use 5 columns on large screens.
function getGridClass(group) {
  if (group === 'faculty') return 'grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6';
  else if (group === 'graduate_alum' || group === 'undergraduate_alum') return 'grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 gap-6';
  return 'grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6';
}


const GROUPS = {
  faculty: { title: 'Faculty', intro: 'Our faculty lead research programs and supervise students. They direct our lab’s research, teaching and outreach.' },
  graduate: { title: 'Graduate Students', intro: 'PhD and Master\'s students working on core research projects and thesis-driven work.' },
  undergraduate: { title: 'Undergraduate Students', intro: 'Undergraduates contributing to projects, prototyping, and data work through research opportunities.' },
  graduate_alum: { title: 'Graduate Alumni'},
  undergraduate_alum: { title: 'Undergraduate Alumni'},
};

function membersByGroup(group) {
  return people.filter((p) => (p.group || 'graduate') === group);
}

// Fisher-Yates shuffle (non-destructive)
function shuffle(arr) {
  const a = arr.slice();
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

// Return a shuffled/ordered list for a group.
// For 'graduate' we put PhD students first, then Master's, then others, with shuffling within each.
// For alumni groups, sort by grad_date (most recent first).
// All other groups are shuffled.
function getOrderedMembers(group) {
  const list = membersByGroup(group);
  if (group === 'graduate') {
    const phd = list.filter((p) => /ph\.?\s*d/i.test(p.title));
    const masters = list.filter((p) => /master|m\.?s|msc|master's/i.test(p.title) && !/ph\.?d/i.test(p.title));
    const others = list.filter((p) => !phd.includes(p) && !masters.includes(p));
    return [
      ...shuffle(phd).map(p => ({ ...p, _subgroup: 'phd' })),
      ...shuffle(masters).map(p => ({ ...p, _subgroup: 'masters' })),
      ...shuffle(others).map(p => ({ ...p, _subgroup: 'others' }))
    ];
  }
  if (group === 'graduate_alum' || group === 'undergraduate_alum') {
    const withDate = list.filter((p) => p.grad_date);
    const withoutDate = list.filter((p) => !p.grad_date);
    // Sort by grad_date descending (most recent first)
    withDate.sort((a, b) => new Date(b.grad_date).getTime() - new Date(a.grad_date).getTime());
    return [...withDate, ...withoutDate];
  }
  // Shuffle all other groups (faculty, undergraduates)
  return shuffle(list);
}

---

<SectionedCardPage
  metadata={metadata}
  title="Lab Members"
  intro="Meet the people driving our research—faculty, graduate students, and undergraduates collaborating on projects across perception, autonomy, and systems engineering."
>
  {Object.keys(GROUPS).map((g) => {
    const list = getOrderedMembers(g);
    return list.length ? (
      <>
        {/* Visual divider before alumni sections */}
        {g === 'graduate_alum' && (
          <div class="my-16 border-t-2 border-gray-200 dark:border-gray-700 pt-12">
            <h2 class="text-3xl font-bold mb-2 text-center">Alumni</h2>
            <p class="text-center text-muted mb-12">
              Former lab members who have graduated and moved on to exciting careers and opportunities.
            </p>
          </div>
        )}
        <section class="mb-12">
          <div class="flex items-baseline justify-between mb-4">
            <h2 class="text-2xl font-semibold">{GROUPS[g].title}</h2>
            {/* <p class="text-sm text-muted hidden sm:block">{list.length} member{list.length > 1 ? 's' : ''}</p> */}
          </div>
          <p class="text-muted mb-6 max-w-3xl">{GROUPS[g].intro}</p>

          <div class={getGridClass(g)}>
            {list.map((p, i) => (
              <EntityCard
                href={`/people/${p.slug}`}
                title={p.name}
                subtitle={p.title}
                image={p.photo}
                imageAlt={p.name}
                imageStyle={IMAGE_STYLE}
                imageDimensions={IMAGE_DIMENSIONS}
                priority={g === 'faculty' && i < 2}
                links={p.links}
                cardClass={
                  g === 'faculty'
                    ? 'motion-safe:md:animate-fade'
                    : 'intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade intersect-quarter'
                }
                cardStyle={g === 'faculty' ? `animation-delay: ${i * 100}ms` : undefined}
                dataSubgroup={p._subgroup}
                titleClass={g === 'graduate_alum' || g === 'undergraduate_alum' ? 'text-sm font-semibold' : 'text-lg font-semibold'}
                subtitleClass={g === 'graduate_alum' || g === 'undergraduate_alum' ? 'text-xs text-gray-500' : 'text-sm text-gray-500'}
              />
            ))}
          </div>
        </section>
      </>
    ) : null;
  })}
</SectionedCardPage>
