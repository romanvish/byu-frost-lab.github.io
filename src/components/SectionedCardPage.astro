---
import PageLayout from '~/layouts/PageLayout.astro';

const {
  metadata,
  title,
  intro,
  maxWidthClass = 'max-w-4xl',
  headerClass = 'pt-12 pb-6',
  sectionClass = 'py-8',
} = Astro.props;

const hasHeaderSlot = Astro.slots.has('header');
const hasIntroSlot = Astro.slots.has('intro');
---

<PageLayout metadata={metadata}>
  {hasHeaderSlot ? (
    <slot name="header" />
  ) : (
    <header class={`${maxWidthClass} mx-auto px-4 ${headerClass}`}>
      {title ? <h1 class="text-4xl md:text-5xl font-heading font-bold mb-3">{title}</h1> : null}
      {hasIntroSlot ? (
        <slot name="intro" />
      ) : intro ? (
        <p class="text-lg text-muted max-w-3xl">{intro}</p>
      ) : null}
    </header>
  )}

  <section class={`${maxWidthClass} mx-auto px-4 ${sectionClass}`}>
    <slot />
  </section>
</PageLayout>
